# ─── Repo Auditor — Required ───────────────────────────────────────────────
# Kimi K2.6 via OpenRouter. Get your key at https://openrouter.ai/keys
# The auditor defaults to Kimi K2.6. Without this, audits will fail.
OPENROUTER_API_KEY=sk-or-...here

# ─── Repo Auditor — PR Publishing (optional) ──────────────────────────────
# GitHub personal access token with 'public_repo' scope.
# Without this, PR generation works but publishing won't.
GITHUB_TOKEN=github...here
