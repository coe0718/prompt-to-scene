# ─── Required ──────────────────────────────────────────────────────────────
# OpenRouter API key — used by all models in the pipeline
# Kimi K2.6 (structural, aggregation, fixer) + MiniMax M2.7 (deep analysis, PR selector)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=***

# ─── PR Publishing (optional) ──────────────────────────────────────────────
# GitHub personal access token with 'public_repo' scope.
# Without this, PR generation works in dry-run mode but won't publish.
GITHUB_TOKEN=***

# ─── Server ──────────────────────────────────────────────────────────────
PORT=7041
