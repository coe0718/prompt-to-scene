# ─── Repo Auditor — Required ───────────────────────────────────────────────
# Kimi K2.5 via NVIDIA NIM. Get your key at https://build.nvidia.com/
# The auditor defaults to Kimi. Without this, audits will fail.
NVIDIA_API_KEY=nvapi-your-key-here

# ─── Repo Auditor — PR Publishing (optional) ──────────────────────────────
# GitHub personal access token with 'public_repo' scope.
# Without this, PR generation works but publishing won't.
GITHUB_TOKEN=github_pat_your-token-here

# ─── Repo Auditor — Fallback LLM (optional) ──────────────────────────────
# Used if NVIDIA_API_KEY is not set.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Prompt-to-Scene — Music Generation (optional) ───────────────────────
# Suno AI API key. Only needed for audio generation in the creative tool.
SUNO_API_KEY=